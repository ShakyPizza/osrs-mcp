# ── Anthropic (default) ──────────────────────────────────────────────────────
# Required when VISION_PROVIDER is unset or set to "anthropic"
ANTHROPIC_API_KEY=your-api-key-here

# ── Local AI via LM Studio (or any Anthropic-compatible server) ───────────────
# Set VISION_PROVIDER=local to skip the Anthropic API entirely.
# Your local model must be vision/multimodal capable (e.g. qwen2-vl-7b-instruct,
# llava-llama3, llama3.2-vision). Text-only models cannot analyze screenshots.
#
# VISION_PROVIDER=local
# LOCAL_AI_BASE_URL=http://localhost:1234
# LOCAL_AI_API_KEY=lmstudio
# LOCAL_AI_DETAIL_MODEL=qwen2-vl-7b-instruct
# LOCAL_AI_FAST_MODEL=qwen2-vl-7b-instruct
#
# Set to "1" to enable thinking/reasoning if your local model supports it:
# LOCAL_AI_THINKING=0
