{
  "name": "osrs-mcp",
  "version": "0.1.0",
  "description": "MCP server for Old School RuneScape — screen analysis, wiki lookups, and GE prices",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "osrs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
